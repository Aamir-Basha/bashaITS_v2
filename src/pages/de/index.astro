---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomePage from "../../components/pages/HomePage.astro";
import { actions } from "astro:actions";
import { t } from "../../i18n/utils";

export const prerender = false;

const lang = "de" as const;
const result = Astro.getActionResult(actions.contact);
---

<BaseLayout title={t(lang, "pages.home.title")} description={t(lang, "pages.home.description")} lang={lang}>
  <HomePage lang={lang} result={result} contactAction={actions.contact} />
</BaseLayout>
