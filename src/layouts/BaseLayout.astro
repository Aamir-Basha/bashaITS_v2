---
import SEO from "../components/SEO.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { defaultLang, type Lang } from "../i18n/ui";
import {
  getAlternateUrls,
  getCanonicalPath,
  getCommonStructuredData,
  getWebPageStructuredData,
  pageSeo,
  siteConfig,
  toAbsoluteUrl,
  type SeoPageKey,
} from "../seo/config";
import "../styles/global.css";

interface Props {
  lang?: Lang;
  page: SeoPageKey;
  image?: string;
  noindex?: boolean;
  type?: "website" | "article";
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { lang = defaultLang, page, image, noindex = false, type = "website", structuredData } = Astro.props;

const siteBase = Astro.site ?? new URL(Astro.url.origin);
const meta = pageSeo[lang][page];
const canonicalPath = getCanonicalPath(page, lang);
const canonicalUrl = toAbsoluteUrl(canonicalPath, siteBase);
const alternates = getAlternateUrls(page, siteBase);
const commonStructuredData = getCommonStructuredData(siteBase);
const pageStructuredData = getWebPageStructuredData({ page, lang, canonical: canonicalUrl });
const allStructuredData = structuredData
  ? [commonStructuredData.organization, commonStructuredData.website, pageStructuredData, ...(Array.isArray(structuredData) ? structuredData : [structuredData])]
  : [commonStructuredData.organization, commonStructuredData.website, pageStructuredData];
---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- Global document meta: change site-level metadata in src/seo/config.ts -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={siteConfig.siteName} />

    <!-- Page-level SEO component -->
    <SEO
      title={meta.title}
      description={meta.description}
      ogTitle={meta.ogTitle}
      ogDescription={meta.ogDescription}
      twitterTitle={meta.twitterTitle}
      twitterDescription={meta.twitterDescription}
      lang={lang}
      canonical={canonicalUrl}
      alternates={alternates}
      image={image ?? siteConfig.defaultSocialImage}
      type={type}
      noindex={noindex}
      structuredData={allStructuredData}
    />
  </head>

  <body>
    <!-- Change global top navigation style in src/components/Navbar.astro + global.css -->
    <Navbar lang={lang} />

    <!-- Main page content from each route file -->
    <main class="site-main">
      <slot />
    </main>

    <!-- Change global footer style in src/components/Footer.astro + global.css -->
    <Footer lang={lang} />
  </body>
</html>
