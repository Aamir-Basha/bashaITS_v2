---
import Button from "./Button.astro";

interface Props {
  title: string;
  text: string;
  href: string;
  buttonLabel: string;
}

const { title, text, href, buttonLabel } = Astro.props;
---
<section class="section section--compact">
  <div class="container">
    <div class="card center-text section-surface">
      <h2 class="page-title">{title}</h2>
      <p class="page-intro cta-intro">{text}</p>
      <div class="mt-6">
        <Button href={href}>{buttonLabel}</Button>
      </div>
    </div>
  </div>
</section>
