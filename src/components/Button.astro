---
interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary";
  class?: string;
  disabled?: boolean;
}

const {
  href,
  type = "button",
  variant = "primary",
  class: className = "",
  disabled = false,
} = Astro.props;

const classes = `btn btn--${variant} ${className}`.trim();
---
{
  href ? (
    <a href={href} class={classes} aria-disabled={disabled ? "true" : undefined}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} disabled={disabled}>
      <slot />
    </button>
  )
}
