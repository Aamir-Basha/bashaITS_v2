---
import Container from "../Container.astro";
import { defaultLang, type Lang } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section">
  <Container>
    <h1 class="page-title">{t("legal.privacyHeading")}</h1>

    <div class="mt-6 stack-md section-surface" style="max-width: 72ch;">
      <div>
        <h2>1. {lang === "de" ? "Allgemeine Hinweise" : "General information"}</h2>
        <p class="mt-4">{lang === "de" ? "Die folgenden Hinweise geben einen Überblick darüber, was mit Ihren personenbezogenen Daten beim Besuch dieser Website passiert." : "The following information provides an overview of what happens to your personal data when you visit this website."}</p>
      </div>

      <div>
        <h2>2. {lang === "de" ? "Verantwortliche Stelle" : "Controller"}</h2>
        <p class="mt-4">Aamir Mosa Basha<br />LudwigStr. 29<br />38106 Braunschweig<br />{lang === "de" ? "Deutschland" : "Germany"}<br />E-Mail: basha.IT.Solution@gmail.com</p>
      </div>

      <div>
        <h2>3. {lang === "de" ? "Datenerfassung über das Kontaktformular" : "Data collection via contact form"}</h2>
        <p class="mt-4">{lang === "de" ? "Wenn Sie uns über das Kontaktformular Anfragen senden, werden die Angaben inklusive Kontaktdaten zum Zweck der Bearbeitung und für mögliche Rückfragen gespeichert." : "If you send inquiries via the contact form, the submitted information including contact details will be stored for processing your request and possible follow-up questions."}</p>
      </div>

      <div>
        <h2>4. {lang === "de" ? "Zweck der Verarbeitung" : "Purpose of processing"}</h2>
        <p class="mt-4">{lang === "de" ? "Die Verarbeitung Ihrer Daten erfolgt ausschließlich zur Bearbeitung Ihrer Anfrage und zur Kontaktaufnahme." : "Your data is processed solely for handling your request and contacting you."}</p>
      </div>

      <div>
        <h2>5. {lang === "de" ? "Hosting & E-Mail-Versand" : "Hosting & email delivery"}</h2>
        <p class="mt-4">{lang === "de" ? "Für den Versand von Anfragen wird ein externer E-Mail-Dienstleister (Resend) verwendet. Dabei können personenbezogene Daten (z. B. Name, E-Mail-Adresse, Nachricht) verarbeitet werden." : "An external email provider (Resend) is used to deliver inquiries. Personal data (e.g., name, email address, message) may be processed."}</p>
      </div>

      <div>
        <h2>6. {lang === "de" ? "Ihre Rechte" : "Your rights"}</h2>
        <p class="mt-4">{lang === "de" ? "Sie haben jederzeit das Recht auf Auskunft über gespeicherte personenbezogene Daten sowie auf Berichtigung oder Löschung im Rahmen der gesetzlichen Vorgaben." : "You have the right to request information about stored personal data as well as correction or deletion within the scope of legal requirements."}</p>
      </div>
    </div>
  </Container>
</section>
