---
import Button from "../Button.astro";
import Card from "../Card.astro";
import Container from "../Container.astro";
import Section from "../Section.astro";
import { defaultLang, type Lang } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section">
  <Container>
    <Section kicker={t("contact.kicker")} title={t("contact.title")} intro={t("contact.copy")} titleAs="h1" compact>
      <div class="grid-2">
        <div class="section-surface" aria-hidden="true"></div>
        <Card title={t("contact.inquiryTitle")} class="section-surface">
          <div class="stack-sm">
            <p><strong>{t("contact.emailLabel")}</strong> basha.IT.Solution@gmail.com</p>
            <p><strong>{t("contact.locationLabel")}</strong> {t("brand.location")}</p>
            <p><strong>{t("contact.focusLabel")}</strong> {t("contact.focusValue")}</p>
          </div>
          <div class="mt-6">
            <Button href="mailto:basha.IT.Solution@gmail.com">{t("contact.cta")}</Button>
          </div>
        </Card>
      </div>
    </Section>
  </Container>
</section>
