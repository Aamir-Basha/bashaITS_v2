---
import ContactCTA from "../ContactCTA.astro";
import Container from "../Container.astro";
import Section from "../Section.astro";
import ServiceCard from "../ServiceCard.astro";
import { defaultLang, type Lang } from "../../i18n/ui";
import { localizePath, useTranslations } from "../../i18n/utils";

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const services = lang === "de"
  ? [
      { title: "Netzwerklösungen", text: "Einrichtung, Optimierung, Fehleranalyse und praxisnaher Support für stabile und effiziente Netzwerke." },
      { title: "Webseiten-Entwicklung", text: "Moderne Webseiten für Unternehmen, Dienstleister, Portfolios und den professionellen Online-Auftritt." },
      { title: "App-Entwicklung", text: "Individuelle App-Lösungen für Workflows, Werkzeuge und interaktive Erlebnisse passend zu Ihren Anforderungen." },
      { title: "SaaS-Entwicklung", text: "Skalierbare Software-Plattformen, Admin-Dashboards, Portale und webbasierte Business-Anwendungen." },
      { title: "Technischer Support", text: "Zuverlässige Unterstützung bei Einrichtung, Fehlerbehebung, Optimierung und technischen Herausforderungen." },
      { title: "Beratung & Planung", text: "Klare technische Ausrichtung für Unternehmen und Einzelpersonen mit einem realistischen, umsetzbaren Weg." },
    ]
  : [
      { title: "Network Solutions", text: "Setup, optimization, troubleshooting, and practical support for stable and efficient networks." },
      { title: "Website Development", text: "Modern websites for businesses, service providers, portfolios, and digital presence upgrades." },
      { title: "App Development", text: "Custom app solutions for workflows, tools, and interactive experiences tailored to your needs." },
      { title: "SaaS Development", text: "Scalable software platforms, admin dashboards, portals, and business-focused web applications." },
      { title: "Technical Support", text: "Reliable help with setup, bug fixing, optimization, and practical problem-solving for digital systems." },
      { title: "Consulting & Planning", text: "Clear technical direction for businesses or individuals who need a smart, realistic path forward." },
    ];
---

<section class="section">
  <Container>
    <Section kicker={t("services.kicker")} title={t("services.title")} intro={t("services.copy")} titleAs="h1" compact>
      <div class="grid-3" style="align-items:stretch;">
        {services.map((service) => <ServiceCard title={service.title} text={service.text} />)}
      </div>
    </Section>
  </Container>
</section>

<ContactCTA
  title={lang === "de" ? "Lassen Sie uns Ihr Projekt besprechen" : "Let's discuss your project"}
  text={lang === "de"
    ? "Sie suchen einen verlässlichen Partner für moderne IT-Lösungen? Schreiben Sie eine kurze Nachricht und wir klären die nächsten sinnvollen Schritte."
    : "Need a reliable partner for modern IT delivery? Send a short message and we will define the most practical next steps."}
  href={localizePath(lang, "/contact")}
  buttonLabel={lang === "de" ? "Projekt anfragen" : "Start your project"}
/>
