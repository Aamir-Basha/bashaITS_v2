---
import Container from "../Container.astro";
import { defaultLang, type Lang } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section">
  <Container>
    <h1 class="page-title">{t("legal.impressumHeading")}</h1>

    <div class="mt-6 stack-md section-surface" style="max-width: 72ch;">
      <div>
        <h2>{lang === "de" ? "Angaben gemäß § 5 TMG" : "Information according to § 5 TMG"}</h2>
        <p class="mt-4">
          Aamir Mosa Basha<br />
          LudwigStr. 29<br />
          38106 Braunschweig<br />
          {lang === "de" ? "Deutschland" : "Germany"}
        </p>
      </div>

      <div>
        <h2>{lang === "de" ? "Kontakt" : "Contact"}</h2>
        <p class="mt-4">E-Mail: basha.IT.Solution@gmail.com</p>
      </div>

      <div>
        <h2>{lang === "de" ? "Umsatzsteuer-ID" : "VAT ID"}</h2>
        <p class="mt-4">{lang === "de" ? "Keine Umsatzsteuer-ID gemäß §19 UStG (Kleinunternehmerregelung)" : "No VAT ID according to §19 UStG (small business regulation)."}</p>
      </div>
    </div>
  </Container>
</section>
