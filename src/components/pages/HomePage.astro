---
import { defaultLang, type Lang } from "../../i18n/ui";
import { localizePath, useTranslations } from "../../i18n/utils";

interface Props {
  lang?: Lang;
  result?: any;
  contactAction: string;
}

const { lang = defaultLang, result, contactAction } = Astro.props;
const t = useTranslations(lang);

const serviceOptions = lang === "de"
  ? [
      ["website-development", "Webseiten-Entwicklung"],
      ["app-development", "App-Entwicklung"],
      ["saas-development", "SaaS-Entwicklung"],
      ["network-solutions", "Netzwerklösungen"],
      ["it-support", "IT-Support"],
      ["not-sure-yet", "Noch unsicher"],
    ]
  : [
      ["website-development", "Website Development"],
      ["app-development", "App Development"],
      ["saas-development", "SaaS Development"],
      ["network-solutions", "Network Solutions"],
      ["it-support", "IT Support"],
      ["not-sure-yet", "Not sure yet"],
    ];
---

<section class="container-main section-shell pt-20 sm:pt-28">
  <div class="relative grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="absolute -left-20 -top-16 h-52 w-52 rounded-full bg-indigo-500/20 blur-3xl"></div>
    <div class="absolute right-0 top-6 h-44 w-44 rounded-full bg-violet-500/20 blur-3xl"></div>

    <div class="relative">
      <p class="section-kicker">{t("home.hero.kicker")}</p>

      <h1 class="max-w-4xl text-5xl font-black leading-[1.05] tracking-tight sm:text-6xl lg:text-7xl">
        {t("home.hero.title")}
      </h1>

      <p class="mt-6 max-w-2xl text-lg text-white/70 sm:text-xl">{t("home.hero.copy")}</p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a href={localizePath(lang, "/contact")} class="btn-primary">{t("home.hero.ctaPrimary")}</a>
        <a href={localizePath(lang, "/services")} class="btn-secondary">{t("home.hero.ctaSecondary")}</a>
      </div>
    </div>

    <div class="glass relative rounded-[2rem] p-6 sm:p-8">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <p class="text-sm text-white/50">{t("home.featured.label")}</p>
          <h2 class="mt-1 text-2xl font-bold">{t("home.featured.title")}</h2>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/5 px-3 py-2 text-xs text-white/70">{t("home.featured.badge")}</div>
      </div>

      <div class="space-y-4">
        <div class="premium-card !rounded-2xl !p-4">
          <h3 class="font-semibold">{lang === "de" ? "Netzwerk-Setup & Optimierung" : "Network Setup & Optimization"}</h3>
          <p class="mt-1 text-sm text-white/65">{lang === "de" ? "Praxisnahe Unterstützung für Router, WLAN, lokale Infrastruktur und Verbindungsprobleme." : "Practical support for routers, Wi-Fi, local infrastructure, and connectivity issues."}</p>
        </div>

        <div class="premium-card !rounded-2xl !p-4">
          <h3 class="font-semibold">{lang === "de" ? "Webseiten- & App-Entwicklung" : "Website & App Development"}</h3>
          <p class="mt-1 text-sm text-white/65">{lang === "de" ? "Klare, moderne und responsive Erlebnisse für einen professionellen Auftritt." : "Clean, modern, responsive experiences that help businesses look professional."}</p>
        </div>

        <div class="premium-card !rounded-2xl !p-4">
          <h3 class="font-semibold">{lang === "de" ? "SaaS & Individuelle Plattformen" : "SaaS & Custom Platforms"}</h3>
          <p class="mt-1 text-sm text-white/65">{lang === "de" ? "Individuelle Systeme, Portale, Dashboards und Produktideen werden greifbar umgesetzt." : "Tailored systems, portals, dashboards, and product ideas brought to life."}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container-main section-shell pt-6">
  <div class="grid gap-10 rounded-[2rem] border border-white/10 bg-white/4 p-8 sm:p-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div>
      <p class="section-kicker">{t("contact.kicker")}</p>
      <h2 class="max-w-xl text-3xl font-bold tracking-tight sm:text-5xl">{lang === "de" ? "Starten Sie mit einer kurzen Nachricht" : "Start with a simple message"}</h2>

      <p class="mt-5 max-w-xl text-lg text-white/70">{lang === "de" ? "Ob Webseite, App, SaaS-Plattform, Netzwerksupport oder eine erste Idee: Sie müssen noch nicht alles perfekt ausgearbeitet haben." : "Whether you need a website, app, SaaS platform, network support, or just want to discuss an idea, you do not need to have everything figured out yet."}</p>

      <p class="mt-4 max-w-xl text-base text-white/50">{lang === "de" ? "Beschreiben Sie kurz Ihr Anliegen und ich melde mich mit einem praktischen nächsten Schritt zurück." : "Tell me briefly what you need, and I'll get back to you with a practical next step."}</p>
    </div>

    <form method="POST" action={contactAction} class="glass rounded-[1.75rem] p-6 sm:p-8" data-contact-form data-sending-text={t("home.contactForm.sending")}>
      <input type="text" name="company" class="hidden" />
      {
        result?.data?.success && <div class="mb-6 rounded-2xl border border-emerald-400/20 bg-emerald-400/10 p-4 text-sm text-emerald-200">{t("home.contactForm.success")}</div>
      }

      {
        result?.error && (
          <div class="mb-6 rounded-2xl border border-red-400/20 bg-red-400/10 p-4 text-sm text-red-200">
            {t("home.contactForm.error")}
            <a href="mailto:basha.IT.Solution@gmail.com" class="underline"> basha.IT.Solution@gmail.com</a>.
          </div>
        )
      }

      <div class="grid gap-5 sm:grid-cols-2">
        <div class="sm:col-span-1">
          <label for="name" class="mb-2 block text-sm font-medium text-white/80">{t("home.contactForm.name")}</label>
          <input id="name" name="name" type="text" required minlength="2" placeholder={t("home.contactForm.namePlaceholder")} class="form-field" />
        </div>

        <div class="sm:col-span-1">
          <label for="email" class="mb-2 block text-sm font-medium text-white/80">{t("home.contactForm.email")}</label>
          <input id="email" name="email" type="email" required placeholder={t("home.contactForm.emailPlaceholder")} class="form-field" />
        </div>

        <div class="sm:col-span-2">
          <label for="service" class="mb-2 block text-sm font-medium text-white/80">{t("home.contactForm.service")}</label>
          <select id="service" name="service" required class="form-field">
            <option value="" class="bg-[#0b1020] text-white">{t("home.contactForm.servicePlaceholder")}</option>
            {serviceOptions.map(([value, label]) => <option value={value} class="bg-[#0b1020] text-white">{label}</option>)}
          </select>
        </div>

        <div class="sm:col-span-2">
          <label for="message" class="mb-2 block text-sm font-medium text-white/80">{t("home.contactForm.message")}</label>
          <textarea id="message" name="message" rows="6" required minlength="10" placeholder={t("home.contactForm.messagePlaceholder")} class="form-field"></textarea>
        </div>
      </div>

      <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm text-white/45">{t("home.contactForm.helper")}</p>
        <button type="submit" class="btn-primary min-w-40" data-submit-btn>{t("home.contactForm.submit")}</button>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector('[data-contact-form]');
  const submitButton = form?.querySelector('[data-submit-btn]');
  const sendingText = form?.getAttribute('data-sending-text') ?? 'Sending…';

  form?.addEventListener('submit', () => {
    if (submitButton instanceof HTMLButtonElement) {
      submitButton.disabled = true;
      submitButton.textContent = sendingText;
      submitButton.classList.add('opacity-80', 'cursor-not-allowed');
    }
  });
</script>
