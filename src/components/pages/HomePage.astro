---
import Button from "../Button.astro";
import Card from "../Card.astro";
import ContactCTA from "../ContactCTA.astro";
import ContactMethodCard from "../ContactMethodCard.astro";
import Container from "../Container.astro";
import Hero from "../Hero.astro";
import Section from "../Section.astro";
import { defaultLang, type Lang } from "../../i18n/ui";
import { localizeHomeContactFormPath, localizePath, useTranslations } from "../../i18n/utils";

interface Props {
  lang?: Lang;
  result?: any;
  contactAction: string;
}

const { lang = defaultLang, result, contactAction } = Astro.props;
const t = useTranslations(lang);

const serviceOptions = lang === "de"
  ? [
      ["website-development", "Webseiten-Entwicklung"],
      ["app-development", "App-Entwicklung"],
      ["saas-development", "SaaS-Entwicklung"],
      ["network-solutions", "Netzwerklösungen"],
      ["it-support", "IT-Support"],
      ["not-sure-yet", "Noch unsicher"],
    ]
  : [
      ["website-development", "Website Development"],
      ["app-development", "App Development"],
      ["saas-development", "SaaS Development"],
      ["network-solutions", "Network Solutions"],
      ["it-support", "IT Support"],
      ["not-sure-yet", "Not sure yet"],
    ];

const heroProofPoints = lang === "de"
  ? ["Klare Roadmap statt Fachjargon", "Messbarer Business-Fokus", "Umsetzung von einer verantwortlichen Stelle"]
  : ["Clear roadmap instead of technical noise", "Business-first outcomes you can measure", "One accountable partner from discovery to launch"];

const heroMetrics = lang === "de"
  ? [
      { value: "48h", label: "für eine erste technische Einschätzung" },
      { value: "End-to-End", label: "von Strategie bis Deployment" },
      { value: "100%", label: "individuell statt Baukasten-Templates" },
    ]
  : [
      { value: "48h", label: "for an initial technical assessment" },
      { value: "End-to-End", label: "from strategy to deployment" },
      { value: "100%", label: "custom implementation over templates" },
    ];

const whyWorkWithMe = lang === "de"
  ? [
      {
        title: "Business-Verständnis + technische Tiefe",
        text: "Ich übersetze Unternehmensziele in saubere technische Entscheidungen, damit Projekte nicht nur funktionieren, sondern wirtschaftlich sinnvoll sind.",
      },
      {
        title: "Senior-Level Umsetzung ohne Agentur-Ballast",
        text: "Sie arbeiten direkt mit der umsetzenden Person. Das reduziert Reibung, beschleunigt Entscheidungen und hält Qualität konstant hoch.",
      },
      {
        title: "Stabilität, Sicherheit und Wartbarkeit",
        text: "Architektur, Code-Struktur und Infrastruktur werden so geplant, dass Ihr System zuverlässig skaliert und langfristig betreibbar bleibt.",
      },
    ]
  : [
      {
        title: "Business strategy paired with technical depth",
        text: "I translate business priorities into architecture decisions so your project is not only functional, but commercially effective.",
      },
      {
        title: "Senior execution without agency overhead",
        text: "You work directly with the person building your solution. Fewer handoffs means faster decisions and consistently high quality.",
      },
      {
        title: "Built for stability, security, and maintainability",
        text: "Code structure, infrastructure, and release workflow are planned to keep your platform dependable as you grow.",
      },
    ];

const processSteps = lang === "de"
  ? [
      {
        phase: "Schritt 1",
        title: "Discovery & Zieldefinition",
        text: "Wir klären Anforderungen, Risiken, Prioritäten und Erfolgskriterien, bevor umgesetzt wird.",
      },
      {
        phase: "Schritt 2",
        title: "Lösungsdesign & technische Roadmap",
        text: "Sie erhalten eine klare Struktur zu Architektur, Umfang, Zeitplan und den nächsten Entscheidungen.",
      },
      {
        phase: "Schritt 3",
        title: "Entwicklung mit transparenten Meilensteinen",
        text: "Lieferung in nachvollziehbaren Etappen mit laufendem Feedback statt Black-Box-Prozess.",
      },
      {
        phase: "Schritt 4",
        title: "Launch, Optimierung & Support",
        text: "Nach dem Go-live begleite ich Stabilität, Performance und sinnvolle Weiterentwicklung.",
      },
    ]
  : [
      {
        phase: "Step 1",
        title: "Discovery and objective definition",
        text: "We align on goals, constraints, risks, and success criteria before implementation starts.",
      },
      {
        phase: "Step 2",
        title: "Solution architecture and technical roadmap",
        text: "You get a clear implementation plan covering architecture, scope, timeline, and key decisions.",
      },
      {
        phase: "Step 3",
        title: "Build phase with transparent milestones",
        text: "Delivery happens in visible increments so you maintain control and context throughout execution.",
      },
      {
        phase: "Step 4",
        title: "Launch, optimization, and support",
        text: "After release, I support reliability, performance, and intentional iteration based on real usage.",
      },
    ];

const clientOutcomes = lang === "de"
  ? [
      "Klare technische Entscheidungen ohne Überforderung",
      "Schnellere Umsetzung mit klarer Verantwortung",
      "Ein professioneller, vertrauenswürdiger digitaler Auftritt",
      "Skalierbare Grundlage für neue Features und Automationen",
      "Dokumentierte Prozesse für Betrieb und Weiterentwicklung",
      "Ein Ansprechpartner mit Gesamtüberblick statt Silos",
    ]
  : [
      "Confident technical decisions without overwhelm",
      "Faster delivery through direct accountability",
      "A digital presence that increases client trust",
      "A scalable foundation for automation and new features",
      "Documented systems your team can operate long-term",
      "One technical partner with full product context",
    ];

const servicePositioning = lang === "de"
  ? [
      {
        title: "Conversion-Websites für Dienstleister & Unternehmen",
        problem: "Viele Webseiten sehen gut aus, erzeugen aber keine qualifizierten Anfragen.",
        solution: "Positionierung, Seitenstruktur, Copy und Conversion-Flow werden entlang realer Kaufentscheidungen aufgebaut.",
        value: "Mehr hochwertige Erstgespräche und ein professioneller Auftritt, der Vertrauen auf den ersten Blick schafft.",
      },
      {
        title: "Individuelle Business-Software & Portale",
        problem: "Wiederkehrende Prozesse laufen über E-Mail, Tabellen und manuelle Abstimmung.",
        solution: "Ich entwickle passgenaue interne Tools, Kundenportale oder SaaS-MVPs mit sauberem Rollen- und Datenmodell.",
        value: "Weniger operative Reibung, schnellere Abläufe und ein digitales System, das mit Ihrem Unternehmen mitwächst.",
      },
      {
        title: "IT-Infrastruktur, Netzwerk & technischer Betrieb",
        problem: "Instabile Infrastruktur und ungeklärte Verantwortlichkeiten kosten Zeit, Geld und Nerven.",
        solution: "Analyse der bestehenden Umgebung, Priorisierung kritischer Risiken und strukturiertes Setup für Sicherheit und Stabilität.",
        value: "Zuverlässiger Alltag im Betrieb und eine belastbare technische Basis für weiteres Wachstum.",
      },
    ]
  : [
      {
        title: "Conversion websites for service businesses",
        problem: "Many websites look modern but fail to generate qualified inbound opportunities.",
        solution: "Positioning, page architecture, copy, and CTA flow are designed around actual buyer decision paths.",
        value: "More high-intent inquiries and a premium digital presence that builds trust from first visit.",
      },
      {
        title: "Custom business software and client portals",
        problem: "Critical workflows often rely on spreadsheets, inboxes, and disconnected manual coordination.",
        solution: "I build custom internal tools, client portals, and SaaS MVPs with clean permissions and resilient data architecture.",
        value: "Lower operational overhead, faster execution, and systems that scale with your business.",
      },
      {
        title: "IT infrastructure, network, and technical operations",
        problem: "Unstable infrastructure and unclear ownership create recurring downtime and avoidable risk.",
        solution: "I audit your setup, prioritize technical risk, and implement a practical reliability and security baseline.",
        value: "Dependable day-to-day operations and a stronger technical foundation for growth initiatives.",
      },
    ];

const portfolioItems = lang === "de"
  ? [
      {
        title: "Lead-optimierte B2B-Unternehmenswebsite",
        type: "Web-Replatforming + Conversion-Optimierung",
        challenge: "Die bestehende Seite war technisch veraltet, unklar positioniert und erzeugte kaum qualifizierte Anfragen.",
        solution: "Neue Informationsarchitektur, klares Messaging, modulare Komponenten und eine fokussierte Kontaktstrecke.",
        stack: "Astro, TypeScript, SEO-Structured-Data, komponentenbasiertes UI-System",
        outcome: "Deutlich professionellerer Markenauftritt und ein klarerer Inbound-Flow für relevante Erstgespräche.",
      },
      {
        title: "Kundenportal für wiederkehrende Serviceprozesse",
        type: "Custom Portal / SaaS-MVP",
        challenge: "Prozesse liefen manuell über E-Mail und Excel, was Reaktionszeit und Nachvollziehbarkeit reduzierte.",
        solution: "Sicheres Portal mit Rollenrechten, strukturierten Workflows, zentralem Datenmodell und definierten Zuständigkeiten.",
        stack: "TypeScript, API-Integration, rollenbasiertes Zugriffsmodell, skalierbare App-Architektur",
        outcome: "Kürzere Durchlaufzeiten, bessere Transparenz für Kunden und klarere operative Steuerung im Team.",
      },
      {
        title: "Netzwerk- und Betriebsmodernisierung im Bestand",
        type: "IT-Operations & Infrastruktur-Optimierung",
        challenge: "Wiederkehrende Störungen und fehlende Standards belasteten den täglichen Betrieb.",
        solution: "Technischer Audit, Priorisierung kritischer Maßnahmen, Stabilitäts- und Sicherheitsverbesserungen in Etappen.",
        stack: "Netzwerkdiagnostik, Monitoring-Baseline, Security-Hardening, dokumentierte Betriebsprozesse",
        outcome: "Mehr Betriebssicherheit, weniger Ausfälle und eine nachvollziehbare Grundlage für zukünftige IT-Entscheidungen.",
      },
    ]
  : [
      {
        title: "Lead-focused B2B company website",
        type: "Web replatform + conversion optimization",
        challenge: "The previous site was outdated, weakly positioned, and generated low-quality inbound inquiries.",
        solution: "Rebuilt the information architecture, sharpened messaging, shipped reusable components, and redesigned contact flow.",
        stack: "Astro, TypeScript, structured SEO data, component-driven UI system",
        outcome: "A stronger market-facing brand presence and a clearer inbound path for qualified sales conversations.",
      },
      {
        title: "Client portal for recurring service operations",
        type: "Custom portal / SaaS MVP",
        challenge: "Core delivery workflows were handled through email and spreadsheets, slowing response cycles.",
        solution: "Implemented a secure portal with role-based access, structured workflows, and centralized operational data.",
        stack: "TypeScript, API integrations, role-based permissions, scalable application architecture",
        outcome: "Faster cycle times, better client visibility, and improved operational control for internal teams.",
      },
      {
        title: "Infrastructure and network reliability modernization",
        type: "IT operations and infrastructure optimization",
        challenge: "Frequent disruptions and unclear technical standards were affecting day-to-day business continuity.",
        solution: "Delivered an infrastructure audit, phased remediation roadmap, and practical security and stability improvements.",
        stack: "Network diagnostics, monitoring baseline, security hardening, documented operational playbooks",
        outcome: "Higher reliability, fewer incidents, and a maintainable foundation for future technical decisions.",
      },
    ];

const technicalCapabilities = lang === "de"
  ? [
      { category: "Engineering", items: ["Astro / Next.js Frontends", "TypeScript Application Architecture", "API- und Datenmodell-Design"] },
      { category: "Product Delivery", items: ["Discovery & Scope Priorisierung", "MVP-Planung mit Business-Fokus", "Release- und Wartungsstrategie"] },
      { category: "Operations", items: ["Netzwerk- und Infrastruktur-Analyse", "Security-Baselines & Hardening", "Monitoring- und Support-Prozesse"] },
    ]
  : [
      { category: "Engineering", items: ["Astro / Next.js frontends", "TypeScript application architecture", "API and data model design"] },
      { category: "Product Delivery", items: ["Discovery and scope prioritization", "Business-focused MVP planning", "Release and maintenance strategy"] },
      { category: "Operations", items: ["Infrastructure and network diagnostics", "Security baselines and hardening", "Monitoring and support playbooks"] },
    ];

const contactUseCases = lang === "de"
  ? [
      "Sie planen eine neue Website oder ein Re-Design mit messbarem Business-Ziel.",
      "Sie wollen interne Prozesse mit einem Portal, Tool oder SaaS-MVP digitalisieren.",
      "Ihre IT- oder Netzwerkumgebung ist instabil und benötigt eine klare Priorisierung.",
    ]
  : [
      "You need a new website or redesign with clear commercial goals.",
      "You want to digitize recurring workflows with a portal, internal tool, or SaaS MVP.",
      "Your IT or network setup feels unstable and needs a practical remediation plan.",
    ];

const contactNextSteps = lang === "de"
  ? [
      "Sie senden eine kurze Anfrage mit Kontext und Ziel.",
      "Innerhalb von 24–48h erhalten Sie eine erste Einschätzung.",
      "In einem kurzen Call definieren wir Umfang, Prioritäten und sinnvolle nächste Schritte.",
    ]
  : [
      "Send a short brief with your current situation and desired outcome.",
      "Receive an initial assessment within 24–48 hours.",
      "Join a focused call to define scope, priorities, and immediate next steps.",
    ];

const contactEmail = "basha.IT.Solution@gmail.com";
const contactPhoneInternational = import.meta.env.PUBLIC_CONTACT_PHONE_INTERNATIONAL ?? import.meta.env.PUBLIC_CONTACT_PHONE ?? "+4915772459178";
const contactPhoneDisplay = import.meta.env.PUBLIC_CONTACT_PHONE_DISPLAY ?? "+49 15772459178";
const contactPhoneHref = `tel:${contactPhoneInternational.replace(/[^\d+]/g, "")}`;
const whatsappNumber = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? contactPhoneInternational).replace(/\D/g, "");
const whatsappPrefilledMessage = lang === "de"
  ? "Hallo Aamir, ich interessiere mich für eine Zusammenarbeit. Können wir kurz über mein Projekt sprechen? / Hi Aamir, I’m interested in working together. Could we briefly discuss my project?"
  : "Hi Aamir, I’m interested in working together. Could we briefly discuss my project? / Hallo Aamir, ich interessiere mich für eine Zusammenarbeit. Können wir kurz über mein Projekt sprechen?";
const contactWhatsAppHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappPrefilledMessage)}`;

const directContactTitle = lang === "de" ? "Wählen Sie den einfachsten Kontaktweg" : "Choose the easiest way to get in touch";
const directContactIntro = lang === "de"
  ? "Für schnelle Abstimmung können Sie direkt anrufen oder per WhatsApp schreiben. Für strukturierte Anforderungen bleibt das Anfrageformular die beste Option."
  : "For faster communication, call directly or send a WhatsApp message. For complete briefs, use the structured inquiry form.";

const contactMethods = lang === "de"
  ? [
      {
        title: "Direkter Anruf",
        helper: "Ideal, wenn Sie Ihr Projekt live besprechen und Prioritäten direkt klären möchten.",
        value: contactPhoneDisplay,
        actionLabel: "Jetzt anrufen",
        href: contactPhoneHref,
        icon: "call" as const,
      },
      {
        title: "WhatsApp",
        helper: "Perfekt für kurze Nachrichten, schnelle Rückfragen und unkomplizierte Erstabstimmung.",
        value: contactPhoneDisplay,
        actionLabel: "Per WhatsApp schreiben",
        href: contactWhatsAppHref,
        icon: "whatsapp" as const,
      },
      {
        title: "Business E-Mail",
        helper: "Bestens geeignet für detaillierte Anfragen mit Kontext, Zielen und Rahmenbedingungen.",
        value: contactEmail,
        actionLabel: "E-Mail verfassen",
        href: `mailto:${contactEmail}`,
        icon: "email" as const,
      },
    ]
  : [
      {
        title: "Direct Call",
        helper: "Best when you want to discuss scope live and align on priorities immediately.",
        value: contactPhoneDisplay,
        actionLabel: "Call now",
        href: contactPhoneHref,
        icon: "call" as const,
      },
      {
        title: "WhatsApp",
        helper: "Great for quick messages, fast clarifications, and lightweight first contact.",
        value: contactPhoneDisplay,
        actionLabel: "Message on WhatsApp",
        href: contactWhatsAppHref,
        icon: "whatsapp" as const,
      },
      {
        title: "Business Email",
        helper: "Ideal for detailed business inquiries with project context and requirements.",
        value: contactEmail,
        actionLabel: "Write an email",
        href: `mailto:${contactEmail}`,
        icon: "email" as const,
      },
    ];
---

<Hero
  kicker={lang === "de" ? "Strategischer Technologiepartner für Wachstum" : "Strategic technology partner for ambitious growth"}
  title={lang === "de"
    ? "Web, Software und IT-Systeme, die Vertrauen schaffen und Umsatz unterstützen"
    : "Web, software, and IT systems engineered to build trust and drive revenue"}
  copy={lang === "de"
    ? "Ich entwickle digitale Lösungen für Unternehmen, die mehr als nur eine schöne Oberfläche wollen: klare Prozesse, starke Nutzererlebnisse und belastbare Technik als Wettbewerbsvorteil."
    : "I build digital solutions for businesses that need more than a polished interface: clear processes, conversion-ready user experiences, and reliable technology that supports real growth."}
  primaryHref={localizeHomeContactFormPath(lang)}
  primaryLabel={lang === "de" ? "Kostenlose Erstberatung" : "Book a Discovery Call"}
  secondaryHref={localizePath(lang, "/services")}
  secondaryLabel={lang === "de" ? "Services ansehen" : "View Services"}
  proofLabel={lang === "de" ? "Warum Entscheider mit mir arbeiten" : "Why decision-makers choose this approach"}
  proofPoints={heroProofPoints}
  metrics={heroMetrics}
/>

<section class="section section--compact section-layered">
  <Container>
    <Section
      kicker={lang === "de" ? "Core Services" : "Core Services"}
      title={lang === "de" ? "Leistungen mit klarem Problem-Solution-Value-Fit" : "Services framed around business problems, technical solutions, and measurable value"}
      intro={lang === "de"
        ? "Jede Leistung ist auf reale Engpässe im Wachstum ausgerichtet — mit nachvollziehbarer Umsetzung statt technischer Black Box."
        : "Every service is structured around real growth bottlenecks, with transparent delivery and business-aligned outcomes."}
      compact
    >
      <div class="grid-3">
        {servicePositioning.map((service) => (
          <Card class="service-position-card reveal-up">
            <h3 class="card-title">{service.title}</h3>
            <p><strong>{lang === "de" ? "Problem:" : "Problem:"}</strong> {service.problem}</p>
            <p class="mt-4"><strong>{lang === "de" ? "Lösung:" : "Solution:"}</strong> {service.solution}</p>
            <p class="mt-4"><strong>{lang === "de" ? "Business-Value:" : "Business value:"}</strong> {service.value}</p>
          </Card>
        ))}
      </div>
    </Section>
  </Container>
</section>

<section class="section section--compact section-layered">
  <Container>
    <Section
      kicker={lang === "de" ? "Why Work With Me" : "Why Work With Me"}
      title={lang === "de" ? "Technische Umsetzung mit klarer Business-Verantwortung" : "Technical execution with business-level accountability"}
      compact
    >
      <div class="grid-3">
        {whyWorkWithMe.map((item) => (
          <Card class="reveal-up">
            <h3 class="card-title">{item.title}</h3>
            <p>{item.text}</p>
          </Card>
        ))}
      </div>
    </Section>
  </Container>
</section>

<section class="section section--compact">
  <Container>
    <Section
      kicker={lang === "de" ? "How I Work" : "How I Work"}
      title={lang === "de" ? "Ein strukturierter Prozess für planbare Ergebnisse" : "A structured delivery process for predictable outcomes"}
      intro={lang === "de"
        ? "Jedes Projekt folgt einem klaren Framework, damit Qualität, Tempo und Transparenz gleichzeitig möglich sind."
        : "Every engagement follows a clear framework so quality, speed, and transparency stay aligned."}
      compact
    >
      <div class="process-grid">
        {processSteps.map((step) => (
          <article class="process-card reveal-up">
            <p class="process-phase">{step.phase}</p>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </Section>
  </Container>
</section>

<section class="section section--compact section-layered">
  <Container>
    <Section
      kicker={lang === "de" ? "What Clients Get" : "What Clients Get"}
      title={lang === "de" ? "Mehr als Code: ein verlässliches Umsetzungssystem" : "More than code: a reliable system for execution"}
      compact
    >
      <div class="section-surface outcomes-surface reveal-up">
        <ul class="outcomes-list">
          {clientOutcomes.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </Section>
  </Container>
</section>

<section class="section section--compact">
  <Container>
    <Section
      kicker={lang === "de" ? "Portfolio Proof" : "Portfolio Proof"}
      title={lang === "de" ? "Projektbeispiele mit klarer Struktur und Business-Ergebnis" : "Portfolio-style case snapshots with clear challenge, solution, and outcomes"}
      intro={lang === "de"
        ? "So werden Projekte dokumentiert und geliefert: verständlich für Entscheider und belastbar für Teams."
        : "How delivery is documented for business stakeholders and implemented for technical teams."}
      compact
    >
      <div class="portfolio-grid">
        {portfolioItems.map((item) => (
          <Card class="showcase-card reveal-up">
            <h3 class="card-title">{item.title}</h3>
            <p class="portfolio-type">{item.type}</p>
            <div class="stack-sm mt-4">
              <p><strong>{lang === "de" ? "Challenge:" : "Challenge:"}</strong> {item.challenge}</p>
              <p><strong>{lang === "de" ? "Solution:" : "Solution:"}</strong> {item.solution}</p>
              <p><strong>{lang === "de" ? "Stack:" : "Stack:"}</strong> {item.stack}</p>
              <p><strong>{lang === "de" ? "Outcome:" : "Outcome:"}</strong> {item.outcome}</p>
            </div>
          </Card>
        ))}
      </div>
    </Section>
  </Container>
</section>

<section class="section section--compact section-layered">
  <Container>
    <Section
      kicker={lang === "de" ? "Technical Credibility" : "Technical Credibility"}
      title={lang === "de" ? "Technische Stärken für belastbare Delivery" : "Technical strengths that support reliable delivery"}
      compact
    >
      <div class="grid-3">
        {technicalCapabilities.map((group) => (
          <article class="tech-capability reveal-up">
            <p class="process-phase">{group.category}</p>
            <ul class="outcomes-list mt-4">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </Section>
  </Container>
</section>

<section id="contact-form" class="section section--compact">
  <Container>
    <div class="grid-2" style="align-items:start;">
      <div class="stack-md section-surface reveal-up">
        <p class="section-kicker">{t("contact.kicker")}</p>
        <h2 class="page-title">{lang === "de" ? "Einfach anfragen — wir klären den Rest strukturiert" : "Reach out in minutes — get a structured next-step plan"}</h2>
        <p>
          {lang === "de"
            ? "Ob Website, Software oder IT-Betrieb: Sie erhalten schnell eine belastbare Ersteinschätzung statt unverbindlicher Standardantworten."
            : "Whether you need web, software, or infrastructure support, you will receive a clear and practical first assessment."}
        </p>

        <div class="direct-contact-block">
          <h3>{directContactTitle}</h3>
          <p>{directContactIntro}</p>
          <div class="contact-methods-grid mt-4">
            {contactMethods.map((method) => <ContactMethodCard {...method} />)}
          </div>
        </div>

        <div>
          <h3>{lang === "de" ? "Wobei ich unterstützen kann" : "What you can contact me about"}</h3>
          <ul class="outcomes-list mt-4">
            {contactUseCases.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div>
          <h3>{lang === "de" ? "So geht es nach Ihrer Anfrage weiter" : "What happens after you contact me"}</h3>
          <ol class="contact-steps mt-4">
            {contactNextSteps.map((item) => <li>{item}</li>)}
          </ol>
        </div>
      </div>

      <form method="POST" action={contactAction} class="form-card section-surface reveal-up" data-contact-form data-sending-text={t("home.contactForm.sending")}>
        <div class="form-head">
          <p class="form-kicker">{lang === "de" ? "Strukturierte Projektanfrage" : "Structured project inquiry"}</p>
          <h3>{lang === "de" ? "Für vollständige Anforderungen und belastbare Einschätzungen" : "Best for complete requirements and a qualified first assessment"}</h3>
        </div>
        <input type="text" name="company" class="hidden-honeypot" />

        {result?.data?.success && <div class="form-message form-message--success">{t("home.contactForm.success")}</div>}

        {
          result?.error && (
            <div class="form-message form-message--error mt-4">
              {t("home.contactForm.error")}
              <a href={`mailto:${contactEmail}`} style="text-decoration:underline;"> {contactEmail}</a>.
            </div>
          )
        }

        <div class="form-grid mt-4">
          <div class="form-row form-row--2">
            <div>
              <label for="name" class="form-label">{t("home.contactForm.name")}</label>
              <input id="name" name="name" type="text" required minlength="2" placeholder={t("home.contactForm.namePlaceholder")} class="form-control" />
            </div>
            <div>
              <label for="email" class="form-label">{t("home.contactForm.email")}</label>
              <input id="email" name="email" type="email" required placeholder={t("home.contactForm.emailPlaceholder")} class="form-control" />
            </div>
          </div>

          <div>
            <label for="service" class="form-label">{t("home.contactForm.service")}</label>
            <select id="service" name="service" required class="form-control">
              <option value="">{t("home.contactForm.servicePlaceholder")}</option>
              {serviceOptions.map(([value, label]) => <option value={value}>{label}</option>)}
            </select>
          </div>

          <div>
            <label for="message" class="form-label">{t("home.contactForm.message")}</label>
            <textarea id="message" name="message" rows="6" required minlength="10" placeholder={t("home.contactForm.messagePlaceholder")} class="form-control"></textarea>
          </div>
        </div>

        <div class="mt-5 contact-submit-row">
          <p class="text-soft">{t("home.contactForm.helper")}</p>
          <div class="contact-submit-group">
            <a class="text-soft contact-email-link" href={`mailto:${contactEmail}`}>{contactEmail}</a>
            <Button type="submit" class="contact-submit" data-submit-btn>{t("home.contactForm.submit")}</Button>
          </div>
        </div>
      </form>
    </div>
  </Container>
</section>

<ContactCTA
  title={lang === "de" ? "Sie möchten ein belastbares digitales Fundament aufbauen?" : "Ready to build a stronger digital foundation for your business?"}
  text={lang === "de"
    ? "Lassen Sie uns in einem kurzen Gespräch klären, welche Lösung den größten geschäftlichen Hebel für Sie bietet."
    : "Let’s identify the highest-leverage next step for your website, software stack, or IT operations in a short discovery call."}
  href={localizeHomeContactFormPath(lang)}
  buttonLabel={lang === "de" ? "Strategiegespräch starten" : "Start Your Strategy Call"}
/>

<script>
  const form = document.querySelector('[data-contact-form]');
  const submitButton = form?.querySelector('[data-submit-btn]');
  const sendingText = form?.getAttribute('data-sending-text') ?? 'Sending…';

  form?.addEventListener('submit', () => {
    if (submitButton instanceof HTMLButtonElement) {
      submitButton.disabled = true;
      submitButton.textContent = sendingText;
    }
  });

  const revealElements = document.querySelectorAll('.reveal-up');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18 },
    );

    revealElements.forEach((element) => observer.observe(element));
  } else {
    revealElements.forEach((element) => element.classList.add('is-visible'));
  }
</script>
