---
import Button from "./Button.astro";

interface Props {
  kicker: string;
  title: string;
  copy: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
}

const props = Astro.props;
---
<section class="section">
  <div class="container">
    <div class="hero-shell">
      <p class="section-kicker">{props.kicker}</p>
      <h1 class="page-title">{props.title}</h1>
      <p class="page-intro">{props.copy}</p>

      <div class="mt-6 hero-actions">
        <Button href={props.primaryHref}>{props.primaryLabel}</Button>
        <Button href={props.secondaryHref} variant="secondary">{props.secondaryLabel}</Button>
      </div>
    </div>
  </div>
</section>
