---
import Button from "./Button.astro";

interface Props {
  kicker: string;
  title: string;
  copy: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
}

const props = Astro.props;
---
<section class="section">
  <div class="container">
    <!-- Hero typography and spacing are controlled by .page-title, .page-intro, and .section in global.css -->
    <p class="section-kicker">{props.kicker}</p>
    <h1 class="page-title">{props.title}</h1>
    <p class="page-intro">{props.copy}</p>

    <!-- Change button colors and hover behavior in .btn classes in global.css -->
    <div class="mt-6" style="display:flex; gap: var(--space-3); flex-wrap: wrap;">
      <Button href={props.primaryHref}>{props.primaryLabel}</Button>
      <Button href={props.secondaryHref} variant="secondary">{props.secondaryLabel}</Button>
    </div>
  </div>
</section>
