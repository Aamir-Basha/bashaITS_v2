---
import Button from "./Button.astro";
import Container from "./Container.astro";
import { defaultLang, languages, type Lang } from "../i18n/ui";
import { localizePath, switchLocalePath, useTranslations } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const navItems = [
  { href: "/", label: t("nav.home") },
  { href: "/services", label: t("nav.services") },
  { href: "/about", label: t("nav.about") },
  { href: "/contact", label: t("nav.contact") },
];

const currentPath = Astro.url.pathname;
const dePath = switchLocalePath(currentPath, "de");
const enPath = switchLocalePath(currentPath, "en");
---

<header class="site-header site-header--future">
  <Container>
    <div class="navbar navbar--future">
      <a href={localizePath(lang, "/")} class="brand brand--future" aria-label={t("brand.name")}>
        <span class="brand-mark brand-mark--future">
          <span class="brand-mark-core">BI</span>
          <span class="brand-mark-ring"></span>
        </span>

        <span class="brand-copy">
          <span class="brand-name">{t("brand.name")}</span>
          <span class="brand-tagline">{t("brand.tagline")}</span>
        </span>
      </a>

      <nav class="nav-links nav-links--future" aria-label="Main navigation">
        {navItems.map((item) => {
          const href = localizePath(lang, item.href);
          const isActive = currentPath === href;

          return (
            <a
              href={href}
              class:list={["nav-link", "nav-link--future", isActive && "is-active"]}
              aria-current={isActive ? "page" : undefined}
            >
              <span class="nav-link-label">{item.label}</span>
              <span class="nav-link-indicator" aria-hidden="true"></span>
            </a>
          );
        })}
      </nav>

      <div class="nav-actions nav-actions--future">
        <div class="nav-status" aria-label="Availability status">
          <span class="nav-status-dot"></span>
          <span>{lang === "de" ? "Verfügbar" : "Available"}</span>
        </div>

        <div class="language-switch language-switch--future">
          <a
            href={enPath}
            class:list={["language-link", "language-link--future", lang === "en" && "is-active"]}
            aria-label={`${t("nav.language")}: ${languages.en}`}
          >
            EN
          </a>
          <a
            href={dePath}
            class:list={["language-link", "language-link--future", lang === "de" && "is-active"]}
            aria-label={`${t("nav.language")}: ${languages.de}`}
          >
            DE
          </a>
        </div>

        <Button href={localizePath(lang, "/contact")}>{t("nav.cta")}</Button>
      </div>

      <div class="mobile-actions mobile-actions--future">
        <Button href={lang === "en" ? dePath : enPath} variant="secondary">
          {lang === "en" ? "DE" : "EN"}
        </Button>
        <Button href={localizePath(lang, "/contact")} variant="secondary">
          {t("nav.mobileCta")}
        </Button>
      </div>
    </div>
  </Container>
</header>