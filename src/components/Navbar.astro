---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[#0b1020]/70 backdrop-blur-xl">
  <div class="container-main flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-white/10 ring-1 ring-white/10">
        <span class="text-sm font-bold text-white">BI</span>
      </div>

      <div class="leading-tight">
        <p class="text-sm font-semibold text-white">Basha IT Solutions</p>
        <p class="text-xs text-white/60">Professional IT solutions without unnecessary complexity</p>
      </div>
    </a>

    <nav class="hidden items-center gap-2 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="rounded-xl px-4 py-2 text-sm text-white/80 transition hover:bg-white/8 hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a href="/contact" class="hidden md:inline-flex btn-primary">
      Get in Touch
    </a>

    <a
      href="/contact"
      class="inline-flex rounded-xl border border-white/15 px-4 py-2 text-sm text-white md:hidden"
    >
      Contact
    </a>
  </div>
</header>