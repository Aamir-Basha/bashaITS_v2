---

<article class="contact-method-card reveal-up">
  <div class="contact-method-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" focusable="false">
      <path d={iconPathMap[icon]}></path>
    </svg>
  </div>
  <div class="contact-method-content">
    <h4>{title}</h4>
    <p>{helper}</p>
    <a class="contact-method-link" href={href}>{actionLabel}</a>
  </div>
</article>
