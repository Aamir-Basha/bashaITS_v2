---
interface Props {
  kicker?: string;
  title?: string;
  intro?: string;
  compact?: boolean;
  titleAs?: "h1" | "h2";
  class?: string;
}

const { kicker, title, intro, compact = false, titleAs = "h2", class: className = "" } = Astro.props;
const HeadingTag = titleAs;
---
<section class:list={["section", compact && "section--compact", className]}>
  <slot name="container-start" />

  {(kicker || title || intro) && (
    <header class="section-header">
      {kicker && <p class="section-kicker">{kicker}</p>}
      {title && <HeadingTag class="page-title">{title}</HeadingTag>}
      {intro && <p class="page-intro">{intro}</p>}
    </header>
  )}

  <slot />
  <slot name="container-end" />
</section>
